}
#plantable .mytd {
  text-align:center;  
  vertical-align: middle;
  font-size: 75%;
  cursor:pointer;
}

.plan_disable {
  background-color:rgba(233,54,54,0.5);
  text-align:center;
}
.plan_renovation {
  background-color:rgba(184,0,255,0.5);
  text-align:center;
}
